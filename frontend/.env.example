# Azure AD / Microsoft Entra Configuration
# Get these values from: https://portal.azure.com -> App registrations

# Azure AD Application (Client) ID
VITE_AZURE_CLIENT_ID=your_app_client_id_here

# Azure AD Tenant ID (or use 'common' for multi-tenant)
VITE_AZURE_TENANT_ID=common

# Redirect URI (must match registered URI in Azure AD)
VITE_AZURE_REDIRECT_URI=http://localhost:5173

# Post Logout Redirect URI
VITE_AZURE_POST_LOGOUT_URI=http://localhost:5173

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api
