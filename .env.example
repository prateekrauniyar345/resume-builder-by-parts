# Resume Builder Configuration

# LLM Provider Configuration (served via /config/llm API endpoint)
# Initial configuration - can be changed via API after startup
# Supported providers: cerebras, openai, anthropic
# Default: cerebras (recommended for cost and performance)

LLM_PROVIDER=cerebras
LLM_MODEL=llama-3.1-70b

# Cerebras Configuration (recommended for cost and performance)
# Get your API key at: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# OpenAI Configuration (alternative)
# Get your API key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic Configuration (alternative)
# Get your API key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# FastAPI Configuration
FASTAPI_ENV=development
FASTAPI_DEBUG=true

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend Configuration
FRONTEND_PORT=5173

